PORT=5000
NODE_ENV=development

# Future: Add database connection strings
# MONGODB_URI=mongodb://localhost:27017/pinterest-intelligence
# POSTGRES_URI=postgresql://user:password@localhost:5432/pinterest_db

# Future: Add authentication secrets
# JWT_SECRET=your-secret-key-here
# SESSION_SECRET=your-session-secret

# AI Services
GROQ_API_KEY=your-groq-api-key

# Amazon Bedrock (Nova Models)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1

# Nova on-demand requires an Inference Profile ID. 
# Using the 'us.' prefix enables stable cross-region routing.
AWS_NOVA_PRO_ID=us.amazon.nova-pro-v1:0
AWS_NOVA_LITE_ID=us.amazon.nova-lite-v1:0

# Optional: Scraper settings
HEADLESS=true
SCRAPER_TIMEOUT_MS=60000
