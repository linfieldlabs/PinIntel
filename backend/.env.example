PORT=5000
NODE_ENV=development

# Amazon Bedrock — Nova Models
# Local dev: set these. In production (ECS), the task IAM role provides credentials automatically.
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# Nova cross-region inference profile IDs (us. prefix = auto-routed across US regions)
AWS_NOVA_LITE_ID=us.amazon.nova-lite-v1:0
AWS_NOVA_PRO_ID=us.amazon.nova-pro-v1:0
AWS_NOVA_MICRO_ID=us.amazon.nova-micro-v1:0

# Frontend URL (production only — used for CORS)
# FRONTEND_URL=https://your-cloudfront-domain.cloudfront.net

# Scraper settings
HEADLESS=true
SCRAPER_TIMEOUT_MS=60000
